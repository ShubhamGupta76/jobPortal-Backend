{
  "info": {
    "_postman_id": "6b4db2db-7f8f-4d89-b50d-6e9f7f3ecb2e",
    "name": "Job Portal Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Working API collection for the Job Portal backend."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api/v1"
    },
    {
      "key": "timestamp",
      "value": "{{$timestamp}}"
    },
    {
      "key": "candidateEmail",
      "value": "candidate{{$timestamp}}@example.com"
    },
    {
      "key": "recruiterEmail",
      "value": "recruiter{{$timestamp}}@example.com"
    },
    {
      "key": "password",
      "value": "password123"
    },
    {
      "key": "candidateToken",
      "value": ""
    },
    {
      "key": "recruiterToken",
      "value": ""
    },
    {
      "key": "jobId",
      "value": ""
    },
    {
      "key": "applicationId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Candidate",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Candidate registration succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.token) {",
                  "  pm.collectionVariables.set('candidateToken', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Candidate Test\",\n  \"email\": \"{{candidateEmail}}\",\n  \"password\": \"{{password}}\",\n  \"phone\": \"9999999999\",\n  \"role\": \"USER\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Register Recruiter",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Recruiter registration succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.token) {",
                  "  pm.collectionVariables.set('recruiterToken', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Recruiter Test\",\n  \"email\": \"{{recruiterEmail}}\",\n  \"password\": \"{{password}}\",\n  \"phone\": \"8888888888\",\n  \"role\": \"RECRUITER\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login Candidate",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Candidate login succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.token) {",
                  "  pm.collectionVariables.set('candidateToken', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{candidateEmail}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login Recruiter",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Recruiter login succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.token) {",
                  "  pm.collectionVariables.set('recruiterToken', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{recruiterEmail}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Get Jobs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/jobs"
          }
        },
        {
          "name": "Create Job",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Job creation succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.id) {",
                  "  pm.collectionVariables.set('jobId', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{recruiterToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"API Test Engineer\",\n  \"description\": \"Validate backend endpoints\",\n  \"location\": \"Remote\",\n  \"jobType\": \"FULL_TIME\",\n  \"experienceLevel\": \"MID\",\n  \"minSalary\": 700000,\n  \"maxSalary\": 1100000,\n  \"skills\": \"Java,Spring,Testing\",\n  \"companyId\": 1\n}"
            },
            "url": "{{baseUrl}}/jobs"
          }
        },
        {
          "name": "Get Job By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/jobs/{{jobId}}"
          }
        },
        {
          "name": "Get My Jobs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{recruiterToken}}"
              }
            ],
            "url": "{{baseUrl}}/jobs/my-jobs"
          }
        },
        {
          "name": "Update Job",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{recruiterToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"API Test Engineer II\",\n  \"location\": \"Hybrid\"\n}"
            },
            "url": "{{baseUrl}}/jobs/{{jobId}}"
          }
        },
        {
          "name": "Delete Job",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{recruiterToken}}"
              }
            ],
            "url": "{{baseUrl}}/jobs/{{jobId}}"
          }
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "Apply To Job",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Application submitted', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.id) {",
                  "  pm.collectionVariables.set('applicationId', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{candidateToken}}"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "jobId",
                  "value": "{{jobId}}",
                  "type": "text"
                },
                {
                  "key": "coverLetter",
                  "value": "Interested in this opportunity",
                  "type": "text"
                }
              ]
            },
            "url": "{{baseUrl}}/applications"
          }
        },
        {
          "name": "Get My Applications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{candidateToken}}"
              }
            ],
            "url": "{{baseUrl}}/applications/my-applications"
          }
        },
        {
          "name": "Get Recruiter Applications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{recruiterToken}}"
              }
            ],
            "url": "{{baseUrl}}/applications/recruiter"
          }
        },
        {
          "name": "Get Applications By Job",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Applications by job loaded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.length > 0) {",
                  "  pm.collectionVariables.set('applicationId', json.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{recruiterToken}}"
              }
            ],
            "url": "{{baseUrl}}/applications/job/{{jobId}}"
          }
        },
        {
          "name": "Update Application Status",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{recruiterToken}}"
              }
            ],
            "url": "{{baseUrl}}/applications/{{applicationId}}/status?status=SHORTLISTED"
          }
        }
      ]
    }
  ]
}
